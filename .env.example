# Figma Personal Access Token
# Generate at: Figma → Settings → Account → Personal access tokens
FIGMA_TOKEN=

# LLM Provider API Keys (set the one you plan to use)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# AWS credentials (used for DynamoDB + CloudWatch Logs)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# DynamoDB persistence (optional — enables persistent free-tier tracking + user projects)
# Set DYNAMODB_TABLE_NAME to enable. Empty = in-memory fallback (default).
DYNAMODB_TABLE_NAME=
DYNAMODB_REGION=us-west-2
# DYNAMODB_ENDPOINT=http://localhost:8000  # For local dev with DynamoDB Local

# CloudWatch Logs region (optional — defaults to us-west-2)
# Log groups: /figma-to-code/app, /figma-to-code/caddy
# AWS_LOGS_REGION=us-west-2

# GitHub OAuth (optional — enables Push to GitHub feature)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Fidelity validation controls
# Minimum % (0..1) of deterministic CSS BEM element classes that must be present in JSX
FIDELITY_MIN_LAYOUT_COVERAGE=0.9
# Block inline sizing/spacing/typography styles in generated JSX
FIDELITY_FORBID_INLINE_SIZING=true
# If true, conversion fails when final fidelity report has any failed check
FIDELITY_REQUIRE_REPORT_PASS=false
