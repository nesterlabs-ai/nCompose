# Figma Personal Access Token
# Generate at: Figma → Settings → Account → Personal access tokens
FIGMA_TOKEN=

# LLM Provider API Keys (set the one you plan to use)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Fidelity validation controls
# Minimum % (0..1) of deterministic CSS BEM element classes that must be present in JSX
FIDELITY_MIN_LAYOUT_COVERAGE=0.9
# Block inline sizing/spacing/typography styles in generated JSX
FIDELITY_FORBID_INLINE_SIZING=true
# If true, conversion fails when final fidelity report has any failed check
FIDELITY_REQUIRE_REPORT_PASS=false
